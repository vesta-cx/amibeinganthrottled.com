		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"gen": "wrangler types",
		"generate-copy": "tsx scripts/generate-copy.ts"
	},
