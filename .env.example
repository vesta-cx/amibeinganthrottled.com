# Copy generation model — always provider/model format
# Default: anthropic/claude-haiku-4-5
# If ANTHROPIC_API_KEY is set and provider is "anthropic", uses Anthropic SDK directly.
# Otherwise falls back to OpenRouter (requires OPENROUTER_API_KEY).
COPY_MODEL=anthropic/claude-haiku-4-5

# Anthropic direct API key — used when COPY_MODEL uses the "anthropic/" prefix
ANTHROPIC_API_KEY=

# OpenRouter API key — used as fallback when Anthropic routing is unavailable
OPENROUTER_API_KEY=
